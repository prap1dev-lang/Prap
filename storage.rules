rules_version = '2';

// Firebase Storage security rules.
// Admins are identified by a custom `admin` claim minted server-side via
// /api/admin/firebase-token (see src/lib/firebase-admin.ts). Brochures are
// publicly readable so the download links on project pages work.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Project brochures — public read, admin-only write (PDF, no size limit).
    match /projects/brochures/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.contentType == 'application/pdf';
      allow delete: if isAdmin();
    }

    // Any other project assets uploaded directly to Firebase — public read,
    // admin-only write.
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    // Everything else is denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
