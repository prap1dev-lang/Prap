# =================================================================
#  PRAP — environment variable template
#
#  This file is COMMITTED TO GIT and visible to anyone with repo access.
#  → Keep it free of real secrets. Use only placeholders / public values.
#  → Real values go into .env.local (gitignored).
# =================================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://prap.in
NEXT_PUBLIC_SITE_NAME=PRAP

# ---- Supabase (PostgreSQL + Storage + Auth) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace-me
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me-keep-secret

# ---- Firebase (Phone OTP + Storage for brochures) ----
# Client — get these from Firebase Console > Project Settings > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only needed if your Storage bucket name is NOT <projectId>.appspot.com
# (newer projects may use <projectId>.firebasestorage.app). Find it in
# Firebase Console > Storage. Leave blank to use the <projectId>.appspot.com default.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Server — Firebase Admin SDK service account
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- WhatsApp (talk-to-expert deep links) ----
# Digits only, with country code, no + or spaces. e.g. 919876543210
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ---- Google Geocoding (reverse-geocode device GPS -> city/area) ----
# Enable "Geocoding API" in Google Cloud Console and restrict the key.
GOOGLE_GEOCODING_API_KEY=
# Browser key for Places Autocomplete on the listing address fields.
# Enable BOTH "Maps JavaScript API" and "Places API" in Google Cloud, then
# restrict this key by HTTP referrer (your domains). Safe to expose (NEXT_PUBLIC).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Surepass.io (KYC) ----
SUREPASS_TOKEN=
SUREPASS_BASE_URL=https://kyc-api.surepass.io/api/v1

# ---- Razorpay / Cashfree (Payments) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Email (Resend / Brevo) ----
RESEND_API_KEY=
EMAIL_FROM="PRAP <noreply@prap.in>"
# A real, monitored inbox for replies & unsubscribe-by-email. Improves sender
# reputation vs a silent no-reply. Must be on a domain verified in Resend.
EMAIL_REPLY_TO="support@prap.in"

# ---- Admin ----
# Comma-separated emails; these auto-become admins on first login.
ADMIN_BOOTSTRAP_EMAILS=admin@prap.in
